{
  "test_cases": [
    {
      "label": "Happy path — exact matches only",
      "request": {
        "internal": [
          { "id": "TXN-001", "amount": 10000, "currency": "NGN", "reference": "PAY-A" },
          { "id": "TXN-002", "amount": 20000, "currency": "NGN", "reference": "PAY-B" }
        ],
        "external": [
          { "id": "EXT-A", "amount": 10000, "currency": "NGN", "reference": "PAY-A" },
          { "id": "EXT-B", "amount": 20000, "currency": "NGN", "reference": "PAY-B" }
        ]
      },
      "expected_summary": {
        "matched": 2,
        "near_matched": 0,
        "unmatched_internal": 0,
        "unmatched_external": 0
      }
    },
    {
      "label": "Mixed — exact, tolerance, and unmatched",
      "request": {
        "internal": [
          { "id": "TXN-001", "amount": 10000, "currency": "NGN", "reference": "PAY-A" },
          { "id": "TXN-002", "amount": 20000, "currency": "NGN", "reference": "PAY-B" },
          { "id": "TXN-003", "amount": 5000,  "currency": "NGN", "reference": "PAY-C" }
        ],
        "external": [
          { "id": "EXT-A", "amount": 10000, "currency": "NGN", "reference": "PAY-A" },
          { "id": "EXT-B", "amount": 20300, "currency": "NGN", "reference": "PAY-B" },
          { "id": "EXT-D", "amount": 7500,  "currency": "NGN", "reference": "PAY-D" }
        ]
      },
      "expected_summary": {
        "matched": 1,
        "near_matched": 1,
        "unmatched_internal": 1,
        "unmatched_external": 1
      }
    },
    {
      "label": "Edge case — empty arrays",
      "request": {
        "internal": [],
        "external": []
      },
      "expected_summary": {
        "matched": 0,
        "near_matched": 0,
        "unmatched_internal": 0,
        "unmatched_external": 0
      }
    },
    {
      "label": "Edge case — all unmatched",
      "request": {
        "internal": [
          { "id": "TXN-001", "amount": 10000, "currency": "NGN", "reference": "PAY-X" }
        ],
        "external": [
          { "id": "EXT-001", "amount": 10000, "currency": "NGN", "reference": "PAY-Z" }
        ]
      },
      "expected_summary": {
        "matched": 0,
        "near_matched": 0,
        "unmatched_internal": 1,
        "unmatched_external": 1
      }
    },
    {
      "label": "Stress — large payload (generate programmatically for load testing)",
      "note": "Generate 500 internal + 500 external transactions, 70% matching, 15% near-match, 15% unmatched. Measure response time.",
      "request": null
    }
  ]
}
